# ==========================================
# LiveKit Configuration
# ==========================================
LIVEKIT_API_KEY="your_livekit_api_key_here"
LIVEKIT_API_SECRET="your_livekit_api_secret_here"
LIVEKIT_URL="wss://your-project-id.livekit.cloud"

# ==========================================
# LLM Configuration (Scaleway / OpenAI Compatible)
# ==========================================
OPENAI_BASE_URL="https://api.scaleway.ai/your-uuid-here/v1"
MODEL_NAME_LLM="qwen3-235b-a22b-instruct-2507"
OPENAI_API_KEY="your_llm_api_key_here"

# ==========================================
# STT MODEL (Speech-To-Text)
# ==========================================
STT_BASE_URL="https://api.scaleway.ai/your-uuid-here/v1"
STT_MODEL_ID="voxtral-small-24b-2507"
STT_API_KEY="your_stt_api_key_here"

# ==========================================
# TTS MODEL (Text-To-Speech - XTTS)
# ==========================================
XTTS_BASE_URL="http://your_xtts_server_ip:port"
VOICE_WAV_NAME="female.wav"
XTTS_LANGUAGE="en"